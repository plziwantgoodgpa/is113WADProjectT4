<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Category</title>

    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/songForm.css">
    <link rel="stylesheet" href="/css/songTable.css">
</head>

<body>

    <nav class="navbar">
        <a href="/" class="nav-brand">🎵 Spotify</a>

        <div class="nav-links">
            <% if (user_role=='admin') { %>
                <a href="/user/index">Users</a>
            <% } %>
            <a href="/song/popularSong">Popular</a>
            <a href="/song/allsong">Songs</a>
            <a href="/category/allCategory" style="color: #ffffff;">Categories</a>
            <a href="/playlist">Playlists</a>

            <% if (typeof username=='undefined' ) { %>
                <a href="/user/login" class="btn btn-outline">Log in</a>
                <% } else { %>
                    <a href="/user/profile?username=<%= username %>" class="btn">Profile (<%= username %>)</a>
                    <a href="/user/logout" class="btn btn-outline">Log out</a>
                    <% } %>
        </div>
    </nav>

    <div class="container">

        <div class="page-header">
            <h1>Edit Category: <span style="color: #1db954;">
                    <%= category.name %>
                </span></h1>
            <a href="/category/allCategory" class="btn btn-outline">← Cancel</a>
        </div>

        <div class="form-container">
            <form action="/category/editCategory" method="POST" class="custom-form">

                <div class="form-group">
                    <label>Category ID (Cannot be changed):</label>
                    <input type="number" name="category_id" value="<%= category.category_id %>" readonly
                        style="background-color: #1a1a1a; color: #666; cursor: not-allowed;">
                </div>

                <div class="form-group">
                    <label>Category Name:</label>
                    <input type="text" name="name" value="<%= category.name %>" required>
                </div>

                <div class="form-group">
                    <label>Description:</label>
                    <textarea name="description" rows="5" required><%= category.description %></textarea>
                </div>
                <% if (typeof error !=='undefined' && error) { %>
                    <div
                        style="color: #ff4d4d; background-color: rgba(255, 77, 77, 0.1); padding: 10px; border-radius: 5px; margin-bottom: 15px; text-align: center; border: 1px solid #ff4d4d;">
                        <strong>⚠️ Error:</strong>
                        <%= error %>
                    </div>
                    <% } %>
                        <button type="submit" class="btn btn-submit">Update Category</button>
            </form>
        </div>

    </div>

</body>

</html>