<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Categories | BeatVault</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/songTable.css">
</head>

<body>

    <nav class="navbar">
        <a href="/" class="nav-brand">🎵 Spotify</a>

        <div class="nav-links">
            <a href="/song/allsong">Songs</a>
            <a href="/category/allCategory" style="color: #ffffff;">Categories</a>
            <a href="/playlist">Playlists</a>

            <% if (username == undefined) { %>
                <a href="/user/login" class="btn btn-outline">Log in</a>
                <% } else { %>
                    <a href="/user/profile?username=<%= username %>" class="btn">Profile (<%= username %>)</a>
                    <a href="/user/logout" class="btn btn-outline">Log out</a>
                    <% } %>
        </div>
    </nav>
    <div class="container">
        <div class="page-header">
            <h1>Browse Categories</h1>
            <% if (user_role=="admin" ) { %>
                <a href="/category/addCategory" class="btn">+ Add New Category</a>
                <% } %>
        </div>

        <% if (categories && categories.length> 0) { %>
            <table class="song-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Category Name</th>
                        <th>Description</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% categories.forEach(function(cat) { %>
                        <tr>
                            <td>
                                <%= cat.category_id %>
                            </td>
                            <td><strong>
                                    <%= cat.name %>
                                </strong></td>
                            <td style="color: #b3b3b3;">
                                <%= cat.description %>
                            </td>
                            <td>
                                <a href="/category/catDetail?categoryID=<%= cat.category_id %>"
                                    class="btn btn-outline btn-small">View Songs</a>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
            <% } else { %>
                <div class="empty-state">
                    <p>There are no categories yet.</p>
                </div>
                <% } %>

    </div>

</body>

</html>