<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Category Details | BeatVault</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/songDetailPage.css">
    <link rel="stylesheet" href="/css/songTable.css">
</head>

<body>

    <nav class="navbar">
        <a href="/" class="nav-brand">🎵 Spotify</a>

        <div class="nav-links">
            <a href="/song/allsong">Songs</a>
            <a href="/category/allCategory" style="color: #ffffff;">Categories</a>
            <a href="/playlist">Playlists</a>

            <% if (username==undefined) { %>
                <a href="/user/login" class="btn btn-outline">Log in</a>
                <% } else { %>
                    <a href="/user/profile?username=<%= username %>" class="btn">Profile (<%= username %>)</a>
                    <a href="/user/logout" class="btn btn-outline">Log out</a>
                    <% } %>
        </div>
    </nav>

    <div class="container">

        <div class="page-header">
            <h1>Category Details</h1>
            <a href="/category/allCategory" class="btn btn-outline">← Back to Categories</a>
        </div>

        <% if (category !=undefined && category !="Not Found" ) { %>

            <div class="content-box">
                <table class="info-table">
                    <!-- <tr>
                        <th>Category ID</th>
                        <td><%= //category.category_id %></td>
                    </tr> -->
                    <tr>
                        <th>Category Name</th>
                        <td><strong style="font-size: 1.2em; color: #1db954;">
                                <%= category.name %>
                            </strong></td>
                    </tr>
                    <tr>
                        <th>Description</th>
                        <td>
                            <%= category.description %>
                        </td>
                    </tr>
                </table>

                <% if (typeof user_role !=='undefined' && user_role=="admin" ) { %>
                    <div class="admin-controls"
                        style="margin-top: 20px; padding-top: 20px; border-top: 1px solid #333;">
                        <a href="/category/editCategory?categoryID=<%= category.category_id %>"
                            class="btn btn-outline">Edit Category</a>
                        <a href="/category/deleteCategory?categoryID=<%= category.category_id %>" class="btn"
                            style="background-color: #e74c3c;"
                            onclick="return confirm('Delete this category completely?');">Delete Category</a>
                    </div>
                    <% } %>
            </div>

            <hr class="divider">

            <div class="songs-section">
                <h2>Songs in <%= category.name %>
                </h2>

                <% if (songs && songs.length> 0) { %>
                    <table class="song-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Song Name</th>
                                <th>Artist</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% songs.forEach(function(song) { %>
                                <tr>
                                    <td>
                                        <%= song.song_id %>
                                    </td>
                                    <td><strong>
                                            <%= song.songname %>
                                        </strong></td>
                                    <td>
                                        <%= song.artist %>
                                    </td>
                                    <td>
                                        <a href="/song/songDetail?songID=<%= song.song_id %>"
                                            class="btn btn-outline btn-small">View Details</a>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                    <% } else { %>
                        <div class="empty-state">
                            <p>There are no songs in this category yet.</p>
                            <% if (typeof user_role !=='undefined' && user_role=="admin" ) { %>
                                <br>
                                <a href="/song/addSong" class="btn mt-3">Add a Song</a>
                                <% } %>
                        </div>
                        <% } %>
            </div>

            <% } else { %>
                <div class="empty-state">
                    <p><strong>Sorry!</strong> We couldn't find a category with that ID.</p>
                    <a href="/category/allCategory" class="btn mt-3">Back to Categories</a>
                </div>
                <% } %>

    </div>

</body>

</html>