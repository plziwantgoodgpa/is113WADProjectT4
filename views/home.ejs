<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Music App | Home</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <nav class="navbar">
        <a href="/" class="nav-brand">🎵 Spotify</a>

        <div class="nav-links">
            <a href="/song/allsong">Songs</a>
            <a href="/category/allCategory">Categories</a>
            <a href="/playlist">Playlists</a>

            <% if (!user || user == "Not logged in") { %>
                <a href="/user/login" class="btn btn-outline">Log in</a>
                <% } else { %>
                <a href="/user/profile" class="btn">Profile (<%= user.username %>)</a>
                
                <a href="/user/logout" class="btn btn-outline">Log out</a>
            <% } %>
        </div>
    </nav>

    <div class="hero">
        <% if (!user || user == "Not logged in") { %>
            <h1>Welcome to Spotify Playlist</h1>
            <p>Your ultimate destination for discovering, reviewing, and organizing your favorite music. Log in to start building your playlists and sharing your thoughts on the latest tracks.</p>
            <a href="/song/allsong" class="btn" style="padding: 15px 30px; font-size: 18px;">Browse Library</a>
        <% } else { %>
            <h1>Welcome back, <%= user.username %>!</h1>
            <p>Ready to discover some new tunes? Dive back into the library, check out your playlists, or leave a review on that song you couldn't stop listening to today.</p>
            <a href="/playlist" class="btn" style="padding: 15px 30px; font-size: 18px;">Go to My Playlists</a>
        <% } %>
    </div>

</body>
</html>