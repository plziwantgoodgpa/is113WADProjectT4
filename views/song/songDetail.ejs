<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Song Details | BeatVault</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/songDetailPage.css">
    <link rel="stylesheet" href="/css/songTable.css">
</head>
<body>

    <nav class="navbar">
        <a href="/" class="nav-brand">🎵 Spotify</a>

        <div class="nav-links">
            <a href="/song/allSong" style="color: #ffffff;">Songs</a>
            <a href="/category/allCategory">Categories</a>
            <a href="/playlist">Playlists</a>

            <% if (username == undefined) { %>
                <a href="/user/login" class="btn btn-outline">Log in</a>
            <% } else { %>
                <a href="/user/profile?username=<%= username %>" class="btn">Profile (<%= username %>)</a>
                <a href="/user/logout" class="btn btn-outline">Log out</a>
            <% } %>
        </div>
    </nav>

    <div class="container">
        
        <div class="page-header">
            <h1>Song Details</h1>
            <a href="/song/allSong" class="btn btn-outline">← Back to Library</a>
        </div>

        <% if (song != undefined && song != "Not Found") { %>
            
            <div class="content-box">
                <table class="info-table">
                    <tr>
                        <th>Song ID</th>
                        <td><%= song.song_id %></td>
                    </tr>
                    <tr>
                        <th>Song Name</th>
                        <td><strong style="font-size: 1.2em;"><%= song.songname %></strong></td>
                    </tr>
                    <tr>
                        <th>Artist</th>
                        <td><%= song.artist %></td>
                    </tr>
                    <tr>
                        <th>Category</th>
                        <td><span class="category-badge"><%= song.category %></span></td>
                    </tr>
                    <tr>
                        <th>Description</th>
                        <td><%= song.description %></td>
                    </tr>
                    <tr>
                        <th>Average Rating</th>
                        <td>
                            <span class="rating-badge">
                                <% if (averageRating > 0) { %>
                                    ⭐ <%= averageRating.toFixed(1) %> / 5.0
                                <% } else { %>
                                    No ratings yet
                                <% } %>
                            </span>
                        </td>
                    </tr>
                </table>
                
                <% if (typeof userRole !== 'undefined' && userRole == "admin") { %>
                    <div class="admin-controls" style="margin-top: 20px; padding-top: 20px; border-top: 1px solid #333;">
                        <a href="/song/editSong?songID=<%= song.song_id %>" class="btn btn-outline">Edit Song</a>
                        <a href="/song/deleteSong?songID=<%= song.song_id %>" class="btn" style="background-color: #e74c3c;" onclick="return confirm('Delete this song?');">Delete Song</a>
                    </div>
                <% } %>
            </div>

            <hr class="divider">

            <div class="reviews-section">
                <h2>Reviews</h2>

                <% if (error) { %>
                    <div class="error-box"><strong>Error:</strong> <%= error %></div>
                <% } %>

                <% if (username) { %>
                    <% if (userReview) { %>
                        <div class="review-card user-review-card">
                            <span class="badge">Your Review</span>
                            <div class="review-rating">⭐ <%= userReview.rating %> / 5</div>
                            <p class="review-text">"<%= userReview.reviewMessage %>"</p>
                            <!-- // edit review -->
                            <!-- // delete review -->

                            <div style="margin-top: 20px;">
                                <details>
                                    <summary class="btn btn-outline" style="cursor: pointer;">Edit Your Review</summary>

                                    <div class="review-form-box content-box" style="margin-top: 15px;">
                                        <form action="/review/editReview" method="POST" class="custom-form">
                                            <input type="hidden" name="song_id" value="<%= song.song_id %>">

                                            <div class="form-group">
                                                <label>Rating (1 to 5):</label>
                                                <input type="number" name="rating" min="1" max="5" value="<%= userReview.rating %>" required>
                                            </div>

                                            <div class="form-group">
                                                <label>Your Review:</label>
                                                <textarea name="reviewMessage" rows="4" required><%= userReview.reviewMessage %></textarea>
                                            </div>

                                            <button type="submit" class="btn">Update Review</button>
                                        </form>
                                    </div>
                                </details>

                                <form action="/review/delete-review" method="POST" style="margin-top: 15px;">
                                    <input type="hidden" name="song_id" value="<%= song.song_id %>">
                                    <button type="submit" class="btn" style="background-color: #e74c3c;" onclick="return confirm('Delete your review?');">
                                        Delete Review
                                    </button>
                                </form>

                            </div>
                        </div>
                    <% } else { %>
                        <div class="review-form-box content-box">
                            <h3>Leave a Review</h3>

                            <form action="/review/add-review" method="POST" class="custom-form">
                                <input type="hidden" name="song_id" value="<%= song.song_id %>">
                                
                                <div class="form-group">
                                    <label>Rating (1 to 5):</label>
                                    <input type="number" name="rating" min="1" max="5" value="<%= formData.rating %>" required>
                                </div>
                                
                                <div class="form-group">
                                    <label>Your Review:</label>
                                    <textarea name="reviewMessage" rows="4" required><%= formData.reviewMessage %></textarea>
                                </div>
                                
                                <button type="submit" class="btn">Submit Review</button>
                            </form>

                        </div>
                    <% } %>
                <% } else { %>
                    <div class="login-prompt">
                        <p><em>Please <a href="/user/login" style="color: #1db954;">log in</a> to leave a review.</em></p>
                    </div>
                <% } %>

                <div class="review-list">
                    <% if (reviews && reviews.length > 0) { %>
                        <% reviews.forEach(function(review) { %>
                            <div class="review-card <%= username && review.username === username ? 'user-review-card' : '' %>">
                                <% if (username && review.username === username) { %>
                                    <span class="badge">Your Review</span>
                                <% } %>
                                <div class="review-rating">⭐ <%= review.rating %> / 5</div>
                                <p class="review-text"><%= review.reviewMessage %></p>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="empty-state">
                            <p>There are no reviews for this song yet. Be the first!</p>
                        </div>
                    <% } %>
                </div>
            </div>

        <% } else { %>
            <div class="empty-state">
                <p><strong>Sorry!</strong> We couldn't find a song with that ID in our database.</p>
                <a href="/song/allSong" class="btn mt-3">Back to Library</a>
            </div>
        <% } %>

    </div>

</body>
</html>