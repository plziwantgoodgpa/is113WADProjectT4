<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Search Results</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/songTable.css">
</head>

<body>

    <nav class="navbar">
        <a href="/" class="nav-brand">🎵 BeatVault</a>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/song/allsong" style="color: #ffffff;">Songs</a>
        </div>
    </nav>

    <div class="container">
        <div class="page-header">
            <h1>Search the Song Library</h1>
            <a href="/song/allSong" class="btn btn-outline">Clear Search / View All</a>
        </div>

        <div class="search-container">
            <form action="/song/search" method="GET" class="search-form">
                <input type="text" name="searchTerm" value="<%= searchTerm || '' %>"
                    placeholder="Search by Song Name or Category...">
                <button type="submit" class="btn">Search</button>
            </form>
        </div>

        <h2>Results <%= searchTerm ? 'for "' + searchTerm + '"' : '' %>
        </h2>

        <% if (songs && songs.length> 0) { %>
            <table class="song-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Song Name</th>
                        <th>Artist</th>
                        <th>Category</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% songs.forEach(function(song) { %>
                        <tr>
                            <td>
                                <%= song.song_id %>
                            </td>
                            <td><strong>
                                    <%= song.songname %>
                                </strong></td>
                            <td>
                                <%= song.artist %>
                            </td>
                            <td><span class="category-badge">
                                    <%= song.category %>
                                </span></td>
                            <td>
                                <a href="/song/songDetail?songID=<%= song.song_id %>"
                                    class="btn btn-outline btn-small">View Details</a>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
            <% } else { %>
                <div class="empty-state">
                    <p>No songs found matching <strong>"<%= searchTerm %>"</strong>. Try another word!</p>
                </div>
                <% } %>

    </div>

</body>

</html>