<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Search Results</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/songTable.css">
</head>

<body>

    <nav class="navbar">
        <a href="/" class="nav-brand">🎵 Spotify</a>

        <div class="nav-links">
            <% if (user_role=='admin') { %>
                <a href="/user/index">Users</a>
            <% } %>
            <a href="/song/popularSong">Popular</a>
            <a href="/song/allSong">Songs</a>
            <a href="/category/allCategory">Categories</a>
            <a href="/playlist">Playlists</a>

            <% if (username==undefined) { %>
                <a href="/user/login" class="btn btn-outline">Log in</a>
                <% } else { %>
                    <a href="/user/profile?username=<%= username %>" class="btn">Profile (<%= username %>)</a>
                    <a href="/user/logout" class="btn btn-outline">Log out</a>
                    <% } %>
        </div>
    </nav>

    <div class="container">
        <div class="page-header">
            <h1>Search the Song Library</h1>
            <a href="/song/allSong" class="btn btn-outline">Clear Search / View All</a>
        </div>

        <div class="search-container">
            <form action="/song/search" method="GET" class="search-form">
                <input type="text" name="searchTerm" value="<%= searchTerm || '' %>"
                    placeholder="Search by Song Name or Category...">
                <button type="submit" class="btn">Search</button>
            </form>
        </div>

        <h2>Results <%= searchTerm ? 'for "' + searchTerm + '"' : '' %>
        </h2>

        <% if (songs && songs.length> 0) { %>
            <table class="song-table">
                <thead>
                    <tr>
                        <th>Song Name</th>
                        <th>Artist</th>
                        <th>Category</th>
                        <th>Rating</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% songs.forEach(function(song) { %>
                        <tr>
                            <td><strong>
                                    <%= song.songname %>
                                </strong></td>
                            <td>
                                <%= song.artist %>
                            </td>
                            <td><span class="category-badge">
                                    <%= song.category %>
                                </span></td>
                            <td>
                                <span class="rating-badge">
                                    <% if (song.averageRating !="No ratings yet" ) { %>
                                        ⭐ <%= song.averageRating.toFixed(1) %> / 5.0
                                            <% } else { %>
                                                No ratings yet
                                                <% } %>
                                </span>
                            </td>
                            <td>
                                <a href="/song/songDetail?songID=<%= song.song_id %>"
                                    class="btn btn-outline btn-small">View Details</a>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
            <% } else { %>
                <div class="empty-state">
                    <p>No songs found matching <strong>"<%= searchTerm %>"</strong>. Try another word!</p>
                </div>
                <% } %>

    </div>

</body>

</html>