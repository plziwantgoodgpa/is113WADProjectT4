<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Song | BeatVault</title>

    <link rel="stylesheet" href="/css/style.css">
     <!-- for nav bar -->
    <link rel="stylesheet" href="/css/songDetailPage.css">
     <!-- for song detail table -->
    <link rel="stylesheet" href="/css/songTable.css">
     <!-- the all song or search result table -->
    <link rel="stylesheet" href="/css/songForm.css">
     <!-- for form control -->
</head>

<body>

    <nav class="navbar">
        <a href="/" class="nav-brand">🎵 Spotify</a>

        <div class="nav-links">
            <a href="/song/allsong" style="color: #ffffff;">Songs</a>
            <a href="/category/allCategory">Categories</a>
            <a href="/playlist">Playlists</a>

            <% if (username == undefined) { %>
                <a href="/user/login" class="btn btn-outline">Log in</a>
                <% } else { %>
                    <a href="/user/profile?username=<%= username %>" class="btn">Profile (<%= username %>)</a>
                    <a href="/user/logout" class="btn btn-outline">Log out</a>
                    <% } %>
        </div>
    </nav>

    <div class="container">

        <div class="page-header">
            <h1>Add a New Song</h1>
            <a href="/song/allSong" class="btn btn-outline">← Cancel</a>
        </div>

        <div class="form-container">
            <form action="/song/addSong" method="POST" class="custom-form">

                <div class="form-group">
                    <label>Song Name:</label>
                    <input type="text" name="songname" placeholder="e.g., Blinding Lights" required>
                </div>

                <div class="form-group">
                    <label>Artist:</label>
                    <input type="text" name="artist" placeholder="e.g., The Weeknd" required>
                </div>

                <div class="form-group">
                    <label>Category:</label>
                    <select name="categoryData" required>
                        <option value="" disabled selected>Select a Category...</option>

                        <% categories.forEach(function(cat) { %>
                            <option value="<%= cat.category_id %>|<%= cat.name %>">
                                <%= cat.name %>
                            </option>
                            <% }) %>

                    </select>
                </div>

                <div class="form-group">
                    <label>Description:</label>
                    <textarea name="description" rows="5" placeholder="Add some details about the song..."
                        required></textarea>
                </div>

                <button type="submit" class="btn btn-submit">Save Song to Database</button>
            </form>
        </div>

    </div>

</body>

</html>