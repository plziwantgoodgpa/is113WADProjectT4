<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= playlist.PlayListName %></title>

    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/songDetailPage.css">
    <link rel="stylesheet" href="/css/songTable.css">
</head>
<body>

    <nav class="navbar">
        <a href="/" class="nav-brand">🎵 Spotify</a>

        <div class="nav-links">
            <% if (user.role=='admin') { %>
                <a href="/user/index">Users</a>
            <% } %>
            <a href="/song/popularSong">Popular</a>
            <a href="/song/allsong">Songs</a>
            <a href="/category/allCategory">Categories</a>
            <a href="/playlist" style="color: #ffffff;">Playlists</a>
            <a href="/user/profile" class="btn">Profile</a>
            <a href="/user/logout" class="btn btn-outline">Log out</a>
        </div>
    </nav>

    <div class="container">

        <div class="page-header">
            <h1>Playlist Details</h1>
            <a href="/playlist" class="btn btn-outline">← Back to Playlists</a>
        </div>

        <div class="content-box">
            <table class="info-table">
                <tr>
                    <th>Playlist Name</th>
                    <td><strong style="font-size: 1.2em;"><%= playlist.PlayListName %></strong></td>
                </tr>
                <tr>
                    <th>Date Created</th>
                    <td><%= playlist.date_created %></td>
                </tr>
            </table>

            <div class="admin-controls" style="margin-top: 20px; padding-top: 20px; border-top: 1px solid #333;">
                <a href="/playlist/edit/<%= playlist.playList_id %>" class="btn btn-outline">Edit Playlist Name</a>
                <a href="/playlist/<%= playlist.playList_id %>/addsong" class="btn">+ Add Song</a>
                <a href="/playlist/delete/<%= playlist.playList_id %>" class="btn" style="background-color: #e74c3c;" onclick="return confirm('Delete this playlist?')">Delete Playlist</a>
            </div>
        </div>

        <hr class="divider">

        <div class="songs-section">
            <h2>Songs</h2>

            <% if (playlist.songs.length === 0) { %>
                <div class="empty-state">
                    <p>No songs yet.</p>
                </div>
            <% } else { %>
                <table class="song-table">
                    <thead>
                        <tr>
                            <th>Song Name</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% songs.forEach(function(song) { %>
                            <tr>
                                <td><%= song.songname %></td>
                                <td>
                                    <a href="/playlist/remove/<%= playlist.playList_id %>/<%= song.song_id %>" class="btn btn-outline btn-small">
                                        Remove
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } %>
        </div>

    </div>

</body>
</html>