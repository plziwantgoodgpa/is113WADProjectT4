<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Songs</title>

    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/songTable.css">
</head>
<body>

    <nav class="navbar">
        <a href="/" class="nav-brand">🎵 Spotify</a>
        <div class="nav-links">
            <a href="/song/allsong">Songs</a>
            <a href="/category/allCategory">Categories</a>
            <a href="/playlist" style="color: #ffffff;">Playlists</a>
            <a href="/user/profile" class="btn">Profile</a>
            <a href="/user/logout" class="btn btn-outline">Log out</a>
        </div>
    </nav>

    <div class="container">

        <div class="page-header">
            <h1>Add Songs to "<%= playlist.PlayListName %>"</h1>
            <a href="/playlist/<%= playlist.playList_id %>" class="btn btn-outline">← Back to Playlist</a>
        </div>

        <!-- Search -->
        <div class="search-container">
            <div class="search-form">
                <input 
                    type="text" 
                    id="searchInput"
                    placeholder="Search by song name or artist..." 
                    oninput="filterSongs(this.value)"
                >
            </div>
        </div>

        <% if (songs.length === 0) { %>
            <div class="empty-state">
                <h2>No songs available</h2>
                <p>There are no songs in the library yet.</p>
            </div>
        <% } else { %>
            <% const addedIds = playlist.songs.map(s => s.song_id); %>
            <table class="song-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Song Name</th>
                        <th>Artist</th>
                        <th>Category</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="songList">
                    <% songs.forEach((song, index) => { %>
                        <tr data-name="<%= song.songname.toLowerCase() %>" data-artist="<%= song.artist.toLowerCase() %>">
                            <td><%= index + 1 %></td>
                            <td><%= song.songname %></td>
                            <td><%= song.artist %></td>
                            <td><span class="category-badge"><%= song.category %></span></td>
                            <td>
                                <% if (addedIds.includes(song.song_id)) { %>
                                    <span style="color: #1db954; font-weight: 600;">✓ Added</span>
                                <% } else { %>
                                    <a href="/playlist/<%= playlist.playList_id %>/addsong/<%= song.song_id %>" class="btn btn-small">+ Add</a>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>

    </div>

    <script>
        function filterSongs(query) {
            const rows = document.querySelectorAll('#songList tr');
            const q = query.toLowerCase();
            rows.forEach(row => {
                const name = row.dataset.name || '';
                const artist = row.dataset.artist || '';
                row.style.display = (name.includes(q) || artist.includes(q)) ? '' : 'none';
            });
        }
    </script>

</body>
</html>
