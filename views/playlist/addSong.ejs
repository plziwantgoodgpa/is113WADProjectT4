<!DOCTYPE html>
<html lang="en">
<head>
    <title>Add Songs to <%= playlist.PlayListName %> – Spotify Playlist</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --green: #1DB954;
            --green-hover: #1ed760;
            --black: #121212;
            --dark: #181818;
            --card: #282828;
            --card-hover: #333333;
            --text: #FFFFFF;
            --muted: #B3B3B3;
            --border: #ffffff1a;
            --sidebar: 240px;
        }

        body {
            background: var(--black);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            display: flex;
        }

        /* Sidebar */
        .sidebar {
            width: var(--sidebar);
            background: #000;
            padding: 24px 12px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            position: fixed;
            top: 0; left: 0; bottom: 0;
            z-index: 10;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 12px 24px;
        }

        .logo svg { width: 32px; height: 32px; fill: var(--green); }
        .logo-text { font-weight: 700; font-size: 18px; letter-spacing: -0.3px; }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 10px 12px;
            border-radius: 6px;
            color: var(--muted);
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            transition: color 0.15s;
        }

        .nav-item:hover { color: var(--text); }
        .nav-item.active { color: var(--text); }
        .nav-item svg { width: 22px; height: 22px; fill: currentColor; flex-shrink: 0; }

        /* Main */
        .main {
            margin-left: var(--sidebar);
            flex: 1;
            padding: 0 32px 100px;
            min-height: 100vh;
        }

        /* Topbar */
        .topbar {
            position: sticky;
            top: 0;
            background: linear-gradient(var(--dark), transparent);
            padding: 24px 0 16px;
            z-index: 5;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .btn-back {
            width: 32px;
            height: 32px;
            background: rgba(0,0,0,0.6);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            transition: background 0.15s;
            flex-shrink: 0;
        }

        .btn-back:hover { background: rgba(0,0,0,0.8); }
        .btn-back svg { width: 16px; height: 16px; fill: var(--text); }

        .topbar-info h1 {
            font-size: 24px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .topbar-info p {
            color: var(--muted);
            font-size: 13px;
            margin-top: 2px;
        }

        /* Search */
        .search-wrap {
            margin: 8px 0 24px;
            position: relative;
        }

        .search-wrap svg {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            width: 18px;
            height: 18px;
            fill: var(--muted);
            pointer-events: none;
        }

        .search-input {
            width: 100%;
            max-width: 400px;
            padding: 12px 16px 12px 44px;
            background: var(--card);
            border: 1px solid transparent;
            border-radius: 500px;
            color: var(--text);
            font-size: 14px;
            font-family: 'DM Sans', sans-serif;
            outline: none;
            transition: border-color 0.2s, background 0.2s;
        }

        .search-input:focus {
            border-color: var(--green);
            background: var(--card-hover);
        }

        .search-input::placeholder { color: var(--muted); }

        /* Song list */
        .song-list-header {
            display: grid;
            grid-template-columns: 40px 1fr 1fr 120px;
            gap: 16px;
            padding: 0 16px 8px;
            border-bottom: 1px solid var(--border);
            margin-bottom: 8px;
            color: var(--muted);
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .song-row {
            display: grid;
            grid-template-columns: 40px 1fr 1fr 120px;
            gap: 16px;
            padding: 8px 16px;
            border-radius: 6px;
            align-items: center;
            transition: background 0.15s;
            animation: fadeIn 0.3s ease both;
        }

        .song-row:hover { background: var(--card); }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(6px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .song-num {
            color: var(--muted);
            font-size: 15px;
            text-align: center;
        }

        .song-info { overflow: hidden; }

        .song-name {
            font-weight: 600;
            font-size: 15px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .song-artist {
            color: var(--muted);
            font-size: 13px;
            margin-top: 2px;
        }

        .song-category {
            color: var(--muted);
            font-size: 14px;
        }

        .song-actions {
            display: flex;
            justify-content: flex-end;
        }

        .btn-add {
            display: flex;
            align-items: center;
            gap: 6px;
            color: var(--muted);
            text-decoration: none;
            font-size: 13px;
            font-weight: 600;
            padding: 6px 14px;
            border-radius: 500px;
            border: 1px solid var(--muted);
            transition: color 0.15s, border-color 0.15s, background 0.15s;
            white-space: nowrap;
        }

        .btn-add:hover {
            color: #000;
            background: var(--green);
            border-color: var(--green);
        }

        .btn-add svg { width: 14px; height: 14px; fill: currentColor; }

        .empty {
            text-align: center;
            padding: 80px 0;
            color: var(--muted);
        }

        .empty h3 { color: var(--text); font-size: 20px; margin-bottom: 8px; }

        /* already added badge */
        .badge-added {
            font-size: 12px;
            color: var(--green);
            font-weight: 600;
            padding: 6px 14px;
            border-radius: 500px;
            border: 1px solid var(--green);
        }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <nav class="sidebar">
        <div class="logo">
            <svg viewBox="0 0 24 24"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
            <span class="logo-text">Spotify Playlist</span>
        </div>
        <a href="/" class="nav-item">
            <svg viewBox="0 0 24 24"><path d="M12.5 3.247a1 1 0 0 0-1 0L4 7.577V20h4.5v-6a1 1 0 0 1 1-1h5a1 1 0 0 1 1 1v6H20V7.577l-7.5-4.33zm-2-1.732a3 3 0 0 1 3 0l7.5 4.33a2 2 0 0 1 1 1.732V21a1 1 0 0 1-1 1h-6.5a1 1 0 0 1-1-1v-6h-3v6a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V7.577a2 2 0 0 1 1-1.732l7.5-4.33z"/></svg>
            Home
        </a>
        <a href="/playlist" class="nav-item active">
            <svg viewBox="0 0 24 24"><path d="M3 6a1 1 0 0 1 1-1h16a1 1 0 1 1 0 2H4a1 1 0 0 1-1-1zm0 5a1 1 0 0 1 1-1h16a1 1 0 1 1 0 2H4a1 1 0 0 1-1-1zm1 4a1 1 0 1 0 0 2h10a1 1 0 1 0 0-2H4z"/></svg>
            My Playlists
        </a>
        <a href="/song/allsong" class="nav-item">
            <svg viewBox="0 0 24 24"><path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z"/></svg>
            Songs
        </a>
    </nav>

    <!-- Main -->
    <main class="main">
        <div class="topbar">
            <a href="/playlist/<%= playlist.playList_id %>" class="btn-back">
                <svg viewBox="0 0 24 24"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
            </a>
            <div class="topbar-info">
                <h1>Add to "<%= playlist.PlayListName %>"</h1>
                <p>Browse and add songs to your playlist</p>
            </div>
        </div>

        <!-- Search -->
        <div class="search-wrap">
            <svg viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
            <input 
                type="text" 
                class="search-input" 
                id="searchInput"
                placeholder="Search songs..." 
                oninput="filterSongs(this.value)"
            >
        </div>

        <!-- Song List -->
        <% if (songs.length === 0) { %>
            <div class="empty">
                <h3>No songs available</h3>
                <p>There are no songs in the library yet.</p>
            </div>
        <% } else { %>
            <div class="song-list-header">
                <div>#</div>
                <div>Title</div>
                <div>Category</div>
                <div></div>
            </div>

            <div id="songList">
                <% 
                    const addedIds = playlist.songs.map(s => s.song_id);
                %>
                <% songs.forEach((song, index) => { %>
                    <div class="song-row" data-name="<%= song.songname.toLowerCase() %>" data-artist="<%= song.artist.toLowerCase() %>">
                        <div class="song-num"><%= index + 1 %></div>
                        <div class="song-info">
                            <div class="song-name"><%= song.songname %></div>
                            <div class="song-artist"><%= song.artist %></div>
                        </div>
                        <div class="song-category"><%= song.category %></div>
                        <div class="song-actions">
                            <% if (addedIds.includes(song.song_id)) { %>
                                <span class="badge-added">✓ Added</span>
                            <% } else { %>
                                <a href="/playlist/<%= playlist.playList_id %>/addsong/<%= song.song_id %>" class="btn-add">
                                    <svg viewBox="0 0 24 24"><path d="M19 11h-6V5h-2v6H5v2h6v6h2v-6h6z"/></svg>
                                    Add
                                </a>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

    <script>
        function filterSongs(query) {
            const rows = document.querySelectorAll('#songList .song-row');
            const q = query.toLowerCase();
            rows.forEach(row => {
                const name = row.dataset.name || '';
                const artist = row.dataset.artist || '';
                row.style.display = (name.includes(q) || artist.includes(q)) ? '' : 'none';
            });
        }
    </script>

</body>
</html>
