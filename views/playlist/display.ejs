<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Playlists</title>

    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/songTable.css">
</head>
<body>

    <nav class="navbar">
        <a href="/" class="nav-brand">🎵 Spotify</a>
        <div class="nav-links">
            <% if (user.role=='admin') { %>
                <a href="/user/index">Users</a>
            <% } %>
            <a href="/song/popularSong">Popular</a>
            <a href="/song/allsong">Songs</a>
            <a href="/category/allCategory">Categories</a>
            <a href="/playlist" style="color: #ffffff;">Playlists</a>
            <a href="/user/profile" class="btn">Profile</a>
            <a href="/user/logout" class="btn btn-outline">Log out</a>
        </div>
    </nav>

    <div class="container">

        <div class="page-header">
            <h1>My Playlists</h1>
            <a href="/playlist/create" class="btn">+ New Playlist</a>
        </div>

        <% if (playlists.length === 0) { %>
            <div class="empty-state">
                <h2>No playlists yet</h2>
                <p>Create your first playlist and start adding songs.</p>
                <br>
                <a href="/playlist/create" class="btn">+ Create Playlist</a>
            </div>
        <% } else { %>
            <table class="song-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Playlist Name</th>
                        <th>Songs</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% playlists.forEach((playlist, index) => { %>
                        <tr>
                            <td><%= index + 1 %></td>
                            <td>
                                <a href="/playlist/<%= playlist.playList_id %>" style="color: #1db954; text-decoration: none; font-weight: 600;">
                                    <%= playlist.PlayListName %>
                                </a>
                            </td>
                            <td><%= playlist.songs.length %> songs</td>
                            <td><%= new Date(playlist.date_created).toLocaleDateString() %></td>
                            <td style="display: flex; gap: 8px;">
                                <a href="/playlist/<%= playlist.playList_id %>" class="btn btn-small">View</a>
                                <a href="/playlist/delete/<%= playlist.playList_id %>" class="delete-btn btn-small">Delete</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>

    </div>

</body>
</html>
