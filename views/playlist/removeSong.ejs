<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Remove Song</title>

    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/songTable.css">
</head>
<body>

    <nav class="navbar">
        <a href="/" class="nav-brand">🎵 Spotify</a>

        <div class="nav-links">
            <% if (user.role=='admin') { %>
                <a href="/user/index">Users</a>
            <% } %>
            <a href="/song/popularSong">Popular</a>
            <a href="/song/allsong">Songs</a>
            <a href="/category/allCategory">Categories</a>
            <a href="/playlist" style="color: #ffffff;">Playlists</a>
            <a href="/user/profile" class="btn">Profile</a>
            <a href="/user/logout" class="btn btn-outline">Log out</a>
        </div>
    </nav>

    <div class="container">
        <div class="page-header">
            <h1>Remove Song from Playlist</h1>
            <a href="/playlist/<%= playlist.playList_id %>" class="btn btn-outline">← Back to Playlist</a>
        </div>

        <div class="content-box">
            <table class="info-table">
                <tr>
                    <th>Playlist Name</th>
                    <td><strong style="font-size: 1.2em;"><%= playlist.PlayListName %></strong></td>
                </tr>
            </table>
        </div>

        <br>

        <% if (playlist.songs.length === 0) { %>
            <div class="empty-state">
                <p>No songs in this playlist.</p>
            </div>
        <% } else { %>
            <table class="song-table">
                <thead>
                    <tr>
                        <th>Song Name</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% songs.forEach(function(song) { %>
                        <tr>
                            <td><%= song.songname %></td>
                            <td>
                                <a href="/playlist/remove/<%= playlist.playList_id %>/<%= song.song_id %>" class="btn btn-outline btn-small">
                                    Remove
                                </a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </div>

</body>
</html>