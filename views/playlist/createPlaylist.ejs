<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Playlist</title>

    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/songForm.css">
</head>
<body>

    <nav class="navbar">
        <a href="/" class="nav-brand">🎵 Spotify</a>

        <div class="nav-links">
            <% if (user.user_role=='admin') { %>
                <a href="/user/index">Users</a>
            <% } %>
            <a href="/song/popularSong">Popular</a>
            <a href="/song/allsong">Songs</a>
            <a href="/category/allCategory">Categories</a>
            <a href="/playlist" style="color: #ffffff;">Playlists</a>
            <a href="/user/profile" class="btn">Profile</a>
            <a href="/user/logout" class="btn btn-outline">Log out</a>
        </div>
    </nav>

    <div class="container">

        <div class="page-header">
            <h1>Create Playlist</h1>
            <a href="/playlist" class="btn btn-outline">← Back to Playlists</a>
        </div>

        <div class="content-box">
            <form action="/playlist/create" method="POST" class="custom-form">

                <div class="form-group">
                    <label>Playlist Name</label>
                    <input type="text" name="PlayListName" required>
                </div>

                <button type="submit" class="btn">Create Playlist</button>
            </form>
        </div>

    </div>

</body>
</html>
