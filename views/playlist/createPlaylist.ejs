<!DOCTYPE html>
<html lang="en">
<head>
    <title>Create Playlist – Soundwave</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --green: #1DB954;
            --green-hover: #1ed760;
            --black: #121212;
            --dark: #181818;
            --card: #282828;
            --text: #FFFFFF;
            --muted: #B3B3B3;
            --border: #333333;
            --sidebar: 240px;
        }

        body {
            background: var(--black);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            display: flex;
        }

        /* Sidebar */
        .sidebar {
            width: var(--sidebar);
            background: #000;
            padding: 24px 12px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            position: fixed;
            top: 0; left: 0; bottom: 0;
            z-index: 10;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 12px 24px;
        }

        .logo svg { width: 32px; height: 32px; fill: var(--green); }
        .logo-text { font-weight: 700; font-size: 18px; letter-spacing: -0.3px; }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 10px 12px;
            border-radius: 6px;
            color: var(--muted);
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            transition: color 0.15s;
        }

        .nav-item:hover { color: var(--text); }
        .nav-item.active { color: var(--text); }
        .nav-item svg { width: 22px; height: 22px; fill: currentColor; flex-shrink: 0; }

        /* Main */
        .main {
            margin-left: var(--sidebar);
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 32px;
        }

        .card {
            background: var(--dark);
            border-radius: 12px;
            padding: 48px 40px;
            width: 100%;
            max-width: 420px;
            animation: fadeUp 0.4s ease both;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        h1 {
            font-size: 26px;
            font-weight: 700;
            margin-bottom: 28px;
            letter-spacing: -0.5px;
        }

        .form-group {
            margin-bottom: 16px;
        }

        label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 6px;
        }

        input {
            width: 100%;
            padding: 14px 16px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 6px;
            color: var(--text);
            font-size: 15px;
            font-family: 'DM Sans', sans-serif;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        input:focus {
            border-color: var(--green);
            box-shadow: 0 0 0 2px rgba(29,185,84,0.2);
        }

        input::placeholder { color: var(--muted); }

        .btn {
            width: 100%;
            padding: 15px;
            background: var(--green);
            color: #000;
            font-size: 15px;
            font-weight: 700;
            font-family: 'DM Sans', sans-serif;
            border: none;
            border-radius: 500px;
            cursor: pointer;
            margin-top: 24px;
            letter-spacing: 0.5px;
            transition: background 0.15s, transform 0.1s;
        }

        .btn:hover { background: var(--green-hover); transform: scale(1.02); }
        .btn:active { transform: scale(0.98); }

        .back-link {
            display: inline-block;
            margin-top: 20px;
            color: var(--muted);
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            transition: color 0.15s;
        }

        .back-link:hover { color: var(--text); }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <nav class="sidebar">
        <div class="logo">
            <svg viewBox="0 0 24 24"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
            <span class="logo-text">Soundwave</span>
        </div>
        <a href="/" class="nav-item">
            <svg viewBox="0 0 24 24"><path d="M12.5 3.247a1 1 0 0 0-1 0L4 7.577V20h4.5v-6a1 1 0 0 1 1-1h5a1 1 0 0 1 1 1v6H20V7.577l-7.5-4.33zm-2-1.732a3 3 0 0 1 3 0l7.5 4.33a2 2 0 0 1 1 1.732V21a1 1 0 0 1-1 1h-6.5a1 1 0 0 1-1-1v-6h-3v6a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V7.577a2 2 0 0 1 1-1.732l7.5-4.33z"/></svg>
            Home
        </a>
        <a href="/playlist" class="nav-item active">
            <svg viewBox="0 0 24 24"><path d="M3 6a1 1 0 0 1 1-1h16a1 1 0 1 1 0 2H4a1 1 0 0 1-1-1zm0 5a1 1 0 0 1 1-1h16a1 1 0 1 1 0 2H4a1 1 0 0 1-1-1zm1 4a1 1 0 1 0 0 2h10a1 1 0 1 0 0-2H4z"/></svg>
            My Playlists
        </a>
        <a href="/song/allsong" class="nav-item">
            <svg viewBox="0 0 24 24"><path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z"/></svg>
            Songs
        </a>
    </nav>

    <!-- Main -->
    <main class="main">
        <div class="card">
            <h1>Create Playlist</h1>

            <form action="/playlist/create" method="POST">
                <div class="form-group">
                    <label for="PlayListName">Playlist Name</label>
                    <input type="text" id="PlayListName" name="PlayListName" placeholder="My Playlist" required>
                </div>
                <button type="submit" class="btn">Create</button>
            </form>

            <a href="/playlist" class="back-link">← Back</a>
        </div>
    </main>

</body>
</html>
